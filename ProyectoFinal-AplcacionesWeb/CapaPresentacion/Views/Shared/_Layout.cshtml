<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    @RenderBody()

    <!-- Chat Widget -->
    <style>
        #chat-fab {
            position: fixed;
            bottom: 24px;
            right: 24px;
            z-index: 9999;
            display: flex;
            flex-direction: column;
            align-items: flex-end;
            gap: 12px;
        }

        #chat-window {
            display: none;
            width: 340px;
            background: #fff;
            border-radius: 14px;
            overflow: hidden;
            border: 1px solid #e5e7eb;
            box-shadow: 0 8px 32px rgba(0,0,0,0.15);
            flex-direction: column;
        }

        #chat-window.open { display: flex; }

        .chat-header {
            background: #000;
            padding: 14px 16px;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .chat-header-info { display: flex; align-items: center; gap: 10px; }

        .chat-avatar {
            width: 32px; height: 32px;
            border-radius: 50%;
            background: #1565C0;
            display: flex; align-items: center; justify-content: center;
            font-size: 13px; font-weight: 600; color: #fff;
        }

        .chat-name { font-size: 13px; font-weight: 600; color: #fff; }

        .chat-close {
            background: none; border: none; color: #888;
            cursor: pointer; font-size: 18px; line-height: 1; padding: 0;
        }
        .chat-close:hover { color: #fff; }

        #chat-messages {
            height: 300px;
            overflow-y: auto;
            padding: 14px;
            display: flex;
            flex-direction: column;
            gap: 10px;
            background: #f9fafb;
        }

        #chat-messages::-webkit-scrollbar { width: 4px; }
        #chat-messages::-webkit-scrollbar-track { background: transparent; }
        #chat-messages::-webkit-scrollbar-thumb { background: #e5e7eb; border-radius: 4px; }

        .msg-bot { display: flex; gap: 8px; align-items: flex-start; }

        .msg-bot-avatar {
            width: 24px; height: 24px;
            border-radius: 50%; background: #1565C0;
            display: flex; align-items: center; justify-content: center;
            font-size: 10px; font-weight: 600; color: #fff; flex-shrink: 0;
        }

        .bubble-bot {
            background: #fff;
            border: 1px solid #e5e7eb;
            border-radius: 0 10px 10px 10px;
            padding: 8px 12px;
            font-size: 13px;
            color: #111;
            max-width: 240px;
            line-height: 1.5;
        }

        .bubble-user {
            background: #1565C0;
            border-radius: 10px 0 10px 10px;
            padding: 8px 12px;
            font-size: 13px;
            color: #fff;
            max-width: 240px;
            align-self: flex-end;
            line-height: 1.5;
        }

        .bubble-pdf {
            background: #fff;
            border: 1px solid #e5e7eb;
            border-radius: 0 10px 10px 10px;
            padding: 10px 12px;
            font-size: 13px;
            color: #111;
            max-width: 240px;
        }

        .btn-download {
            display: inline-flex; align-items: center; gap: 6px;
            margin-top: 8px; padding: 6px 12px;
            background: #1565C0; color: #fff;
            border-radius: 6px; font-size: 12px;
            font-weight: 600; text-decoration: none;
            border: none; cursor: pointer;
        }
        .btn-download:hover { background: #0d47a1; color: #fff; }

        .chat-input-bar {
            padding: 10px 12px;
            border-top: 1px solid #e5e7eb;
            display: flex; gap: 8px; align-items: center;
            background: #fff;
        }

        .chat-input-bar input {
            flex: 1; font-size: 13px;
            padding: 8px 12px;
            border-radius: 20px;
            border: 1px solid #e5e7eb;
            outline: none;
            font-family: 'Segoe UI', sans-serif;
        }
        .chat-input-bar input:focus { border-color: #1565C0; }

        .chat-send {
            width: 34px; height: 34px;
            border-radius: 50%;
            background: #1565C0;
            border: none; cursor: pointer;
            display: flex; align-items: center; justify-content: center;
            color: #fff; font-size: 14px; flex-shrink: 0;
            transition: background 0.2s;
        }
        .chat-send:hover { background: #0d47a1; }

        .chat-typing {
            display: flex; gap: 4px; align-items: center;
            padding: 8px 12px;
            background: #fff;
            border: 1px solid #e5e7eb;
            border-radius: 0 10px 10px 10px;
            width: fit-content;
        }
        .chat-typing span {
            width: 6px; height: 6px;
            border-radius: 50%; background: #9ca3af;
            animation: bounce 1.2s infinite;
        }
        .chat-typing span:nth-child(2) { animation-delay: 0.2s; }
        .chat-typing span:nth-child(3) { animation-delay: 0.4s; }

        @@keyframes bounce {
            0%, 60%, 100% { transform: translateY(0); }
            30% { transform: translateY(-4px); }
        }

        #fab-btn {
            width: 52px; height: 52px;
            border-radius: 50%;
            background: #000;
            border: none; cursor: pointer;
            display: flex; align-items: center; justify-content: center;
            box-shadow: 0 4px 14px rgba(0,0,0,0.25);
            transition: background 0.2s;
        }
        #fab-btn:hover { background: #222; }
    </style>

    <div id="chat-fab">
        <div id="chat-window">
            <div class="chat-header">
                <div class="chat-header-info">
                    <div class="chat-avatar">A</div>
                    <div>
                        <div class="chat-name">Asistente</div>
                    </div>
                </div>
                <button class="chat-close" onclick="toggleChat()">✕</button>
            </div>
            <div id="chat-messages">
                <div class="msg-bot">
                    <div class="msg-bot-avatar">A</div>
                    <div class="bubble-bot">Hola 👋 Puedo consultar stock, ventas, proveedores y generar reportes PDF. ¿En qué te ayudo?</div>
                </div>
            </div>
            <div class="chat-input-bar">
                <input type="text" id="chat-input" placeholder="Escribe un mensaje..."
                       onkeydown="if(event.key==='Enter') sendChatMsg()" />
                <button class="chat-send" onclick="sendChatMsg()">
                    <i class="bi bi-send-fill"></i>
                </button>
            </div>
        </div>

        <button id="fab-btn" onclick="toggleChat()">
            <i class="bi bi-chat-dots-fill" style="color:#fff; font-size:20px;"></i>
        </button>
    </div>

    <script>
        const WEBHOOK_URL = 'https://incoming-state-antenna-colours.trycloudflare.com/webhook/8dbf0d22-cb3d-467b-9d6f-feb3691088d7';
        let sessionId = 'session_' + Math.random().toString(36).substr(2, 9);

        function toggleChat() {
            const win = document.getElementById('chat-window');
            win.classList.toggle('open');
        }

        function addMessage(tipo, texto) {
            const msgs = document.getElementById('chat-messages');
            if (tipo === 'user') {
                msgs.innerHTML += `<div class="bubble-user">${texto}</div>`;
            } else if (tipo === 'bot') {
                msgs.innerHTML += `
                    <div class="msg-bot">
                        <div class="msg-bot-avatar">A</div>
                        <div class="bubble-bot">${texto}</div>
                    </div>`;
            } else if (tipo === 'pdf') {
                msgs.innerHTML += `
                    <div class="msg-bot">
                        <div class="msg-bot-avatar">A</div>
                        <div class="bubble-pdf">
                            Reporte generado correctamente.
                            <br>
                            <a href="${texto}" target="_blank" class="btn-download">
                                <i class="bi bi-download"></i> Descargar PDF
                            </a>
                        </div>
                    </div>`;
            }
            msgs.scrollTop = msgs.scrollHeight;
        }

        function showTyping() {
            const msgs = document.getElementById('chat-messages');
            msgs.innerHTML += `
                <div class="msg-bot" id="typing-indicator">
                    <div class="msg-bot-avatar">A</div>
                    <div class="chat-typing">
                        <span></span><span></span><span></span>
                    </div>
                </div>`;
            msgs.scrollTop = msgs.scrollHeight;
        }

        function removeTyping() {
            const t = document.getElementById('typing-indicator');
            if (t) t.remove();
        }

        async function sendChatMsg() {
        const input = document.getElementById('chat-input');
        const text = input.value.trim();
        if (!text) return;

        addMessage('user', text);
        input.value = '';
        showTyping();

        try {
            const res = await fetch(WEBHOOK_URL, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ chatInput: text, sessionId })
            });

            removeTyping();

            const contentType = res.headers.get('Content-Type') || '';

            if (contentType.includes('application/pdf')) {
                const blob = await res.blob();
                const url = URL.createObjectURL(blob);
                addMessage('pdf', url);
            } else {
                const rawText = await res.text();
                let output = '';
                try {
                    const data = JSON.parse(rawText);
                    output = data.output || data.text || data.message || rawText;
                } catch {
                    output = rawText;
                }
                addMessage('bot', output);
            }

            } catch (err) {
                removeTyping();
                addMessage('bot', 'Ocurrió un error al conectar con el asistente.');
            }
        }
    </script>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
