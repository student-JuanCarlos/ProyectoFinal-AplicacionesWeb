@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login - Sistema de Inventario y Ventas</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet" />
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { min-height: 100vh; display: flex; font-family: 'Segoe UI', sans-serif; background: #0a0a0a; }

        .left-panel {
            width: 50%;
            background: #0a0a0a;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 3rem;
            position: relative;
            overflow: hidden;
        }
        .left-panel::before {
            content: '';
            position: absolute;
            width: 400px; height: 400px;
            background: #1565C0;
            border-radius: 50%;
            top: -100px; left: -100px;
            opacity: 0.15;
        }
        .left-panel::after {
            content: '';
            position: absolute;
            width: 300px; height: 300px;
            background: #6A1B9A;
            border-radius: 50%;
            bottom: -80px; right: -80px;
            opacity: 0.15;
        }
        .left-content { position: relative; z-index: 1; text-align: center; }
        .brand-icon {
            width: 90px; height: 90px;
            background: #fff;
            border-radius: 24px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 2rem;
        }
        .brand-icon i { font-size: 42px; color: #0a0a0a; }
        .left-content h2 {
            font-size: 30px;
            font-weight: 700;
            color: #fff;
            margin-bottom: 1rem;
            line-height: 1.3;
        }
        .left-content p {
            font-size: 14px;
            color: #666;
            line-height: 1.7;
            max-width: 280px;
            margin: 0 auto 2.5rem;
        }
        .features {
            display: flex;
            flex-direction: column;
            gap: 12px;
            width: 100%;
            max-width: 280px;
        }
        .feature-item {
            display: flex;
            align-items: center;
            gap: 12px;
            background: #111;
            border: 1px solid #222;
            border-radius: 10px;
            padding: 12px 16px;
        }
        .feature-item i { font-size: 18px; color: #1565C0; }
        .feature-item span { font-size: 13px; color: #aaa; }

        .right-panel {
            width: 50%;
            background: #fff;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 3rem;
            border-radius: 24px 0 0 24px;
        }
        .form-box { width: 100%; max-width: 380px; }
        .form-box .welcome { font-size: 13px; color: #1565C0; font-weight: 600; margin-bottom: 0.5rem; }
        .form-box h3 {
            font-size: 30px;
            font-weight: 700;
            color: #111;
            margin-bottom: 0.25rem;
        }
        .form-box .subtitle {
            font-size: 14px;
            color: #999;
            margin-bottom: 2rem;
        }
        .form-label {
            font-size: 12px;
            font-weight: 600;
            color: #444;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 0.4rem;
        }
        .input-wrapper {
            position: relative;
            margin-bottom: 1.25rem;
        }
        .input-wrapper i.input-icon {
            position: absolute;
            left: 14px;
            top: 50%;
            transform: translateY(-50%);
            font-size: 16px;
            color: #bbb;
        }
        .input-wrapper .form-control {
            padding-left: 42px;
            border: 1.5px solid #eee;
            border-radius: 10px;
            height: 48px;
            font-size: 14px;
            transition: border 0.2s;
            background: #fafafa;
        }
        .input-wrapper .form-control:focus {
            border-color: #1565C0;
            background: #fff;
            box-shadow: 0 0 0 3px rgba(21,101,192,0.08);
        }
        .toggle-password {
            position: absolute;
            right: 14px;
            top: 50%;
            transform: translateY(-50%);
            background: none;
            border: none;
            color: #bbb;
            cursor: pointer;
            font-size: 16px;
            padding: 0;
        }
        .toggle-password:hover { color: #555; }
        .btn-login {
            background: #0a0a0a;
            color: #fff;
            border: none;
            border-radius: 10px;
            padding: 0.85rem;
            font-size: 15px;
            font-weight: 600;
            width: 100%;
            margin-top: 0.5rem;
            transition: background 0.2s, transform 0.1s;
        }
        .btn-login:hover { background: #1565C0; }
        .btn-login:active { transform: scale(0.98); }
        .alert-error {
            background: #fff5f5;
            border: 1px solid #ffd0d0;
            border-left: 4px solid #C62828;
            border-radius: 10px;
            padding: 12px 16px;
            font-size: 13px;
            color: #C62828;
            margin-bottom: 1.5rem;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .footer-text {
            text-align: center;
            margin-top: 2rem;
            font-size: 12px;
            color: #bbb;
        }
    </style>
</head>
<body>

<div class="left-panel">
    <div class="left-content">
        <div class="brand-icon">
            <i class="bi bi-box-seam-fill"></i>
        </div>
        <h2>Sistema de Inventario<br />y Ventas</h2>
        <p>Gestiona tu inventario, proveedores y ventas desde un solo lugar.</p>
        <div class="features">
            <div class="feature-item">
                <i class="bi bi-boxes"></i>
                <span>Control de inventario en tiempo real</span>
            </div>
            <div class="feature-item">
                <i class="bi bi-receipt"></i>
                <span>Registro y seguimiento de ventas</span>
            </div>
            <div class="feature-item">
                <i class="bi bi-truck"></i>
                <span>Gestión de proveedores</span>
            </div>
        </div>
    </div>
</div>

<div class="right-panel">
    <div class="form-box">
        <div class="welcome">Bienvenido de vuelta</div>
        <h3>Iniciar sesión</h3>
        <p class="subtitle">Ingresa tus credenciales para continuar</p>

        @if (ViewBag.Error != null)
        {
            <div class="alert-error">
                <i class="bi bi-exclamation-circle-fill"></i>
                @ViewBag.Error
            </div>
        }

        <form method="post" asp-action="Login" asp-controller="Usuario">
            <div class="mb-3">
                <label class="form-label">Correo electrónico</label>
                <div class="input-wrapper">
                    <i class="bi bi-envelope input-icon"></i>
                    <input type="email" name="Email" class="form-control" placeholder="correo@ejemplo.com" required />
                </div>
            </div>
            <div class="mb-3">
                <label class="form-label">Contraseña</label>
                <div class="input-wrapper">
                    <i class="bi bi-lock input-icon"></i>
                    <input type="password" name="Contraseña" id="passwordInput" class="form-control" required />
                    <button type="button" class="toggle-password" onclick="togglePassword()">
                        <i class="bi bi-eye" id="eyeIcon"></i>
                    </button>
                </div>
            </div>
            <button type="submit" class="btn-login">Iniciar sesión</button>
        </form>

        <div class="footer-text">Sistema de Inventario y Ventas &copy; @DateTime.Now.Year</div>
    </div>
</div>

<script>
    function togglePassword() {
        const input = document.getElementById('passwordInput');
        const icon = document.getElementById('eyeIcon');
        if (input.type === 'password') {
            input.type = 'text';
            icon.classList.replace('bi-eye', 'bi-eye-slash');
        } else {
            input.type = 'password';
            icon.classList.replace('bi-eye-slash', 'bi-eye');
        }
    }
</script>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
