@model IEnumerable<CapaPresentacion.Models.VM.ProductoVM>

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Productos</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { display: flex; min-height: 100vh; background: #f5f5f5; font-family: 'Segoe UI', sans-serif; }

        #sidebar {
            width: 250px; min-height: 100vh; background: #000; color: #fff;
            display: flex; flex-direction: column; position: fixed; top: 0; left: 0; z-index: 100;
        }
        .sidebar-brand { padding: 1.5rem 1.25rem; border-bottom: 1px solid #222; }
        .sidebar-brand h5 { font-size: 14px; font-weight: 600; color: #fff; margin: 0; line-height: 1.4; }
        .sidebar-brand small { font-size: 11px; color: #888; }
        .sidebar-section { padding: 1rem 1.25rem 0.25rem; font-size: 10px; color: #555; text-transform: uppercase; letter-spacing: 1px; }
        .sidebar-nav { flex: 1; padding: 0.5rem 0; }
        .sidebar-nav a { display: flex; align-items: center; gap: 10px; padding: 0.6rem 1.25rem; color: #aaa; text-decoration: none; font-size: 14px; transition: all 0.2s; }
        .sidebar-nav a:hover, .sidebar-nav a.active { color: #fff; background: #111; }
        .sidebar-nav a.active { border-left: 3px solid #fff; }
        .sidebar-nav a i { font-size: 16px; }
        .sidebar-footer { padding: 1rem 1.25rem; border-top: 1px solid #222; }
        .sidebar-footer a { display: flex; align-items: center; gap: 10px; color: #aaa; text-decoration: none; font-size: 14px; }
        .sidebar-footer a:hover { color: #fff; }

        #main { margin-left: 250px; flex: 1; padding: 2rem; }

        .page-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 28px; flex-wrap: wrap; gap: 12px; }
        .page-title { font-size: 22px; font-weight: 700; color: #111; margin: 0; }
        .page-subtitle { font-size: 13px; color: #888; margin-top: 2px; }
        .header-actions { display: flex; gap: 10px; align-items: center; }

        .btn-nuevo {
            background: #000; color: #fff; border: none; padding: 10px 20px;
            border-radius: 8px; font-size: 0.875rem; font-weight: 600; cursor: pointer;
            display: flex; align-items: center; gap: 8px; transition: background 0.2s;
        }
        .btn-nuevo:hover { background: #222; }

        .search-input {
            border: 1px solid #e5e7eb; border-radius: 8px; padding: 9px 14px;
            font-size: 0.875rem; color: #111; width: 240px; transition: border-color 0.2s;
        }
        .search-input:focus { border-color: #000; box-shadow: 0 0 0 3px rgba(0,0,0,0.08); outline: none; }

        /* Cards */
        .cards-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 18px; }

        .producto-card {
            background: #fff; border-radius: 14px; box-shadow: 0 1px 4px rgba(0,0,0,0.07);
            overflow: hidden; transition: transform 0.2s, box-shadow 0.2s;
        }
        .producto-card:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(0,0,0,0.1); }

        .card-img {
            width: 100%; height: 160px; object-fit: contain;
            background: #f9fafb; padding: 16px;
        }

        .card-img-placeholder {
            width: 100%; height: 160px; background: #f9fafb;
            display: flex; align-items: center; justify-content: center;
            color: #d1d5db; font-size: 2.5rem;
        }

        .card-body { padding: 14px 16px; }

        .producto-nombre { font-weight: 700; color: #111; font-size: 0.95rem; margin-bottom: 2px; }
        .producto-codigo { font-size: 0.75rem; color: #9ca3af; font-family: monospace; }

        .card-info { margin-top: 10px; display: flex; flex-direction: column; gap: 6px; }
        .card-info-row { display: flex; justify-content: space-between; align-items: center; font-size: 0.82rem; }
        .card-info-label { color: #9ca3af; font-weight: 500; }
        .card-info-value { color: #374151; font-weight: 600; }

        .badge-stock-ok  { background: #d1fae5; color: #065f46; padding: 2px 8px; border-radius: 20px; font-size: 0.73rem; font-weight: 600; }
        .badge-stock-low { background: #fee2e2; color: #991b1b; padding: 2px 8px; border-radius: 20px; font-size: 0.73rem; font-weight: 600; }

        .badge-estado { display: inline-flex; align-items: center; gap: 5px; padding: 3px 10px; border-radius: 20px; font-size: 0.73rem; font-weight: 600; }
        .badge-estado.activo   { background: #d1fae5; color: #065f46; }
        .badge-estado.inactivo { background: #fee2e2; color: #991b1b; }
        .badge-estado::before { content: ''; width: 6px; height: 6px; border-radius: 50%; background: currentColor; }

        .card-footer-acciones { padding: 10px 16px; border-top: 1px solid #f3f4f6; display: flex; gap: 6px; flex-wrap: wrap; }
        .btn-accion { border: none; padding: 6px 0; border-radius: 8px; font-size: 0.75rem; font-weight: 600; cursor: pointer; transition: opacity 0.15s; flex: 1; text-align: center; }
        .btn-accion:hover { opacity: 0.8; }
        .btn-detalle    { background: #f3f4f6; color: #374151; }
        .btn-edit       { background: #dbeafe; color: #1d4ed8; }
        .btn-historial  { background: #fef3c7; color: #92400e; }
        .btn-activar    { background: #d1fae5; color: #065f46; }
        .btn-desactivar { background: #fee2e2; color: #991b1b; }

        /* Modales */
        .modal-content { border: none; border-radius: 12px; box-shadow: 0 20px 60px rgba(0,0,0,0.15); }
        .modal-header { border-bottom: 1px solid #f3f4f6; padding: 20px 24px 16px; }
        .modal-title { font-size: 1rem; font-weight: 700; color: #111; }
        .modal-body { padding: 20px 24px; }
        .modal-footer { border-top: 1px solid #f3f4f6; padding: 16px 24px; }

        .form-label { font-size: 0.8rem; font-weight: 600; color: #374151; margin-bottom: 4px; }
        .form-control, .form-select {
            border: 1px solid #e5e7eb; border-radius: 8px; padding: 9px 12px;
            font-size: 0.875rem; color: #111; width: 100%; transition: border-color 0.2s;
        }
        .form-control:focus, .form-select:focus { border-color: #000; box-shadow: 0 0 0 3px rgba(0,0,0,0.08); outline: none; }

        .btn-cancelar { background: #f3f4f6; color: #374151; border: none; padding: 9px 18px; border-radius: 8px; font-size: 0.875rem; font-weight: 600; cursor: pointer; }
        .btn-guardar { background: #000; color: #fff; border: none; padding: 9px 18px; border-radius: 8px; font-size: 0.875rem; font-weight: 600; cursor: pointer; transition: background 0.2s; }
        .btn-guardar:hover { background: #222; }

        .detalle-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
        .detalle-item label { font-size: 0.72rem; font-weight: 600; color: #9ca3af; text-transform: uppercase; letter-spacing: 0.05em; display: block; margin-bottom: 3px; }
        .detalle-item span { font-size: 0.9rem; color: #111; font-weight: 500; }

        .detalle-img { width: 100%; max-height: 200px; object-fit: contain; background: #f9fafb; border-radius: 8px; padding: 12px; margin-bottom: 16px; }

        /* Historial tabla */
        .historial-tabla { width: 100%; border-collapse: collapse; font-size: 0.82rem; }
        .historial-tabla thead th { padding: 8px 12px; text-align: left; font-size: 0.72rem; font-weight: 600; color: #6b7280; text-transform: uppercase; border-bottom: 1px solid #e5e7eb; }
        .historial-tabla tbody td { padding: 10px 12px; color: #374151; border-bottom: 1px solid #f3f4f6; }
        .historial-tabla tbody tr:last-child td { border-bottom: none; }

        .badge-entrada { background: #d1fae5; color: #065f46; padding: 2px 8px; border-radius: 20px; font-size: 0.72rem; font-weight: 600; }
        .badge-salida  { background: #fee2e2; color: #991b1b; padding: 2px 8px; border-radius: 20px; font-size: 0.72rem; font-weight: 600; }

        .empty-state { text-align: center; padding: 48px 0; color: #9ca3af; }
        .empty-state i { font-size: 2.5rem; margin-bottom: 12px; display: block; }

        .modal-dialog-lg { max-width: 700px; }
    </style>
</head>
<body>

<div id="sidebar">
    <div class="sidebar-brand">
        <h5>Sistema de Inventario<br />y Ventas</h5>
        <small>Panel de control</small>
    </div>
    <nav class="sidebar-nav">
        <div class="sidebar-section">Principal</div>
        <a href="/Usuario/InicioAdministrador"><i class="bi bi-grid-1x2"></i> Dashboard</a>
        <div class="sidebar-section">Gestión</div>
        @if (User.IsInRole("SuperUser"))
        {
            <a href="/Usuario/Index"><i class="bi bi-people"></i> Usuarios</a>
        }
        <a href="/Producto/Index" class="active"><i class="bi bi-box-seam"></i> Productos</a>
        @if (User.IsInRole("Administrador") || User.IsInRole("SuperUser"))
        {
           <a href="/Categoria/Index"><i class="bi bi-tags"></i> Categorías</a>
           <a href="/Proveedor/Index"><i class="bi bi-truck"></i> Proveedores</a>
           <div class="sidebar-section">Inventario & Ventas</div>
           <a href="/MovimientoStock/Index"><i class="bi bi-arrow-left-right"></i> Mov. de Stock</a>
        }
        <a href="/Venta/Index"><i class="bi bi-receipt"></i> Ventas</a>
    </nav>
    <div class="sidebar-footer">
        <a asp-action="CerrarSesion" asp-controller="Usuario"><i class="bi bi-box-arrow-left"></i> Cerrar sesión</a>
    </div>
</div>

<div id="main">
    <div class="page-header">
        <div>
            <h1 class="page-title">Productos</h1>
            <p class="page-subtitle">Gestión de productos del inventario</p>
        </div>
        <div class="header-actions">
            <form method="get" asp-action="Index" asp-controller="Producto" class="d-flex gap-2">
                <input type="text" name="Busqueda" value="@Context.Request.Query["Busqueda"]"
                       class="search-input" placeholder="Buscar producto..." />
                <button type="submit" class="btn-nuevo"><i class="bi bi-search"></i></button>
            </form>
             @if (User.IsInRole("Administrador") || User.IsInRole("SuperUser"))
             {
                 <button class="btn-nuevo" data-bs-toggle="modal" data-bs-target="#modalCreate">
                      <i class="bi bi-plus-lg"></i> Nuevo Producto
                 </button>
             }
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="empty-state">
            <i class="bi bi-box-seam"></i>
            No se encontraron productos
        </div>
    }
    else
    {
        <div class="cards-grid">
            @foreach (var item in Model)
            {
                <div class="producto-card">
                    @if (!string.IsNullOrEmpty(item.FotoActual))
                    {
                        <img src="/@item.FotoActual" alt="@item.NombreProducto" class="card-img" />
                    }
                    else
                    {
                        <div class="card-img-placeholder"><i class="bi bi-image"></i></div>
                    }
                    <div class="card-body">
                        <div class="producto-nombre">@item.NombreProducto</div>
                        <div class="producto-codigo">@item.Codigo</div>
                        <div class="card-info">
                            <div class="card-info-row">
                                <span class="card-info-label">Categoría</span>
                                <span class="card-info-value">@item.categoria?.NombreCategoria</span>
                            </div>
                            <div class="card-info-row">
                                <span class="card-info-label">Precio</span>
                                <span class="card-info-value">S/ @item.PrecioVendido.ToString("0.00")</span>
                            </div>
                            <div class="card-info-row">
                                <span class="card-info-label">Stock</span>
                                <span class="@(item.StockActual <= item.StockMinimo ? "badge-stock-low" : "badge-stock-ok")">
                                    @item.StockActual unidades
                                </span>
                            </div>
                            <div class="card-info-row">
                                <span class="card-info-label">Estado</span>
                                <span class="badge-estado @(item.Estado ? "activo" : "inactivo")">
                                    @(item.Estado ? "Activo" : "Inactivo")
                                </span>
                            </div>
                        </div>
                    </div>
                    <div class="card-footer-acciones">
                        <button class="btn-accion btn-detalle"
                                onclick="abrirDetalle(@item.IdProducto)"
                                data-bs-toggle="modal"
                                data-bs-target="#modalDetalle">
                            <i class="bi bi-eye"></i> Ver
                        </button>
                        @if (User.IsInRole("Administrativo") || User.IsInRole("SuperUser"))
                        {
                            <button class="btn-accion btn-edit"
                                onclick="abrirEdit(@item.IdProducto)"
                                data-bs-toggle="modal"
                                data-bs-target="#modalEdit">
                            <i class="bi bi-pencil"></i> Editar
                            </button>
                        }
                        <button class="btn-accion btn-historial"
                                onclick="abrirHistorial(@item.IdProducto)"
                                data-bs-toggle="modal"
                                data-bs-target="#modalHistorial">
                            <i class="bi bi-clock-history"></i> Historial
                        </button>
                        @if (User.IsInRole("Administrativo") || User.IsInRole("SuperUser"))
                        {
                            <button class="btn-accion @(item.Estado ? "btn-desactivar" : "btn-activar")"
                                  onclick="cambiarEstado(@item.IdProducto)">
                                  @(item.Estado ? "Desactivar" : "Activar")
                            </button>
                        }
                    </div>
                </div>
            }
        </div>
    }
    <div class="row mt-4">
        <div class="col-12 d-flex justify-content-center">
            <nav aria-label="Page Navigation">
                <ul class="pagination pagination-sm">
                    @for(int i = 0; i < ViewBag.paginas; i++)
                    {
                        <li class="page-item @(ViewBag.paginaActual == (i+1) ? "active" : "")">
                            <a class="page-link" asp-route-page="@(i+1)" >@(i+1)</a>
                        </li>
                    }
                </ul>
            </nav>
        </div>
    </div>
</div>

<!-- Modal Create -->
<div class="modal fade" id="modalCreate" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Nuevo Producto</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="formCreate" enctype="multipart/form-data">
                    <input type="hidden" name="IdProducto" value="0" />
                    <div class="row">
                        <div class="col-6 mb-3">
                            <label class="form-label">Nombre Producto</label>
                            <input type="text" name="NombreProducto" class="form-control" required />
                        </div>
                        <div class="col-6 mb-3">
                            <label class="form-label">Fotografía</label>
                            <input type="file" name="Fotografia" class="form-control" accept="image/*" />
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-6 mb-3">
                            <label class="form-label">Categoría</label>
                            <select name="IdCategoria" class="form-select">
                                <option>--SELECCIONE--</option>
                                @foreach (var cat in ViewBag.Categorias)
                                {
                                    <option value="@cat.IdCategoria">@cat.NombreCategoria</option>
                                }
                            </select>
                        </div>
                        <div class="col-6 mb-3">
                            <label class="form-label">Proveedor</label>
                            <select name="IdProveedor" class="form-select">
                                <option>--SELECCIONE--</option>
                                @foreach (var prov in ViewBag.Proveedores)
                                {
                                    <option value="@prov.IdProveedor">@prov.NombreProveedor</option>
                                }
                            </select>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-6 mb-3">
                            <label class="form-label">Costo Obtenido</label>
                            <input type="number" step="0.01" name="CostoObtenido" class="form-control" required />
                        </div>
                        <div class="col-6 mb-3">
                            <label class="form-label">Precio Vendido</label>
                            <input type="number" step="0.01" name="PrecioVendido" class="form-control" required />
                        </div>
                    </div>
                    <div class="modal-footer px-0 pb-0">
                        <button type="button" class="btn-cancelar" data-bs-dismiss="modal">Cancelar</button>
                        <button type="button" class="btn-guardar" onclick="guardarProducto('formCreate')">Guardar</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Modal Detalle -->
<div class="modal fade" id="modalDetalle" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Detalle Producto</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <img id="detalle-img" src="" alt="" class="detalle-img" />
                <div class="detalle-grid">
                    <div class="detalle-item"><label>Nombre</label><span id="detalle-nombre"></span></div>
                    <div class="detalle-item"><label>Código</label><span id="detalle-codigo"></span></div>
                    <div class="detalle-item"><label>Categoría</label><span id="detalle-categoria"></span></div>
                    <div class="detalle-item"><label>Proveedor</label><span id="detalle-proveedor"></span></div>
                    <div class="detalle-item"><label>Costo</label><span id="detalle-costo"></span></div>
                    <div class="detalle-item"><label>Precio</label><span id="detalle-precio"></span></div>
                    <div class="detalle-item"><label>Stock Actual</label><span id="detalle-stock"></span></div>
                    <div class="detalle-item"><label>Estado</label><span id="detalle-estado"></span></div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn-cancelar" data-bs-dismiss="modal">Cerrar</button>
            </div>
        </div>
    </div>
</div>

<!-- Modal Edit -->
<div class="modal fade" id="modalEdit" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Editar Producto</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="formEdit" enctype="multipart/form-data">
                    <input type="hidden" id="edit-id" name="IdProducto" />
                    <input type="hidden" id="edit-fotoactual" name="FotoActual" />
                    <div class="row">
                        <div class="col-6 mb-3">
                            <label class="form-label">Nombre Producto</label>
                            <input type="text" id="edit-nombre" name="NombreProducto" class="form-control" required />
                        </div>
                        <div class="col-6 mb-3">
                            <label class="form-label">Fotografía</label>
                            <input type="file" name="Fotografia" class="form-control" accept="image/*" />
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-6 mb-3">
                            <label class="form-label">Categoría</label>
                            <select id="edit-categoria" name="IdCategoria" class="form-select">
                                @foreach (var cat in ViewBag.Categorias)
                                {
                                    <option value="@cat.IdCategoria">@cat.NombreCategoria</option>
                                }
                            </select>
                        </div>
                        <div class="col-6 mb-3">
                            <label class="form-label">Proveedor</label>
                            <select id="edit-proveedor" name="IdProveedor" class="form-select">
                                @foreach (var prov in ViewBag.Proveedores)
                                {
                                    <option value="@prov.IdProveedor">@prov.NombreProveedor</option>
                                }
                            </select>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-6 mb-3">
                            <label class="form-label">Costo Obtenido</label>
                            <input type="number" step="0.01" id="edit-costo" name="CostoObtenido" class="form-control" required />
                        </div>
                        <div class="col-6 mb-3">
                            <label class="form-label">Precio Vendido</label>
                            <input type="number" step="0.01" id="edit-precio" name="PrecioVendido" class="form-control" required />
                        </div>
                    </div>
                    <div class="modal-footer px-0 pb-0">
                        <button type="button" class="btn-cancelar" data-bs-dismiss="modal">Cancelar</button>
                        <button type="button" class="btn-guardar" onclick="guardarProducto('formEdit')">Guardar</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Modal Historial -->
<div class="modal fade" id="modalHistorial" tabindex="-1">
    <div class="modal-dialog modal-dialog-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Historial de Movimientos</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <table class="historial-tabla">
                    <thead>
                        <tr>
                            <th>Tipo</th>
                            <th>Cantidad</th>
                            <th>Motivo</th>
                            <th>Usuario</th>
                            <th>Fecha</th>
                        </tr>
                    </thead>
                    <tbody id="historial-body">
                    </tbody>
                </table>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn-cancelar" data-bs-dismiss="modal">Cerrar</button>
            </div>
        </div>
    </div>
</div>

@Html.AntiForgeryToken()

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script>
    function abrirDetalle(id) {
        fetch(`/Producto/DetalleProducto/${id}`)
            .then(res => res.json())
            .then(data => {
                document.getElementById('detalle-img').src = data.fotografia ? `/${data.fotografia}` : '';
                document.getElementById('detalle-img').style.display = data.fotografia ? 'block' : 'none';
                document.getElementById('detalle-nombre').textContent = data.nombreProducto;
                document.getElementById('detalle-codigo').textContent = data.codigo;
                document.getElementById('detalle-categoria').textContent = data.categoria?.nombreCategoria || '—';
                document.getElementById('detalle-proveedor').textContent = data.proveedor?.nombreProveedor || '—';
                document.getElementById('detalle-costo').textContent = `S/ ${parseFloat(data.costoObtenido).toFixed(2)}`;
                document.getElementById('detalle-precio').textContent = `S/ ${parseFloat(data.precioVendido).toFixed(2)}`;
                document.getElementById('detalle-stock').textContent = data.stockActual;
                document.getElementById('detalle-estado').textContent = data.estado ? 'Activo' : 'Inactivo';
            });
    }

    function abrirEdit(id) {
        console.log('abrirEdit llamado con id:', id);
        fetch(`/Producto/DetalleProducto/${id}`)
            .then(res => res.json())
            .then(data => {
                console.log('data recibida:', data);
                document.getElementById('edit-id').value = data.idProducto;
                document.getElementById('edit-fotoactual').value = data.fotografia;
                document.getElementById('edit-nombre').value = data.nombreProducto;
                document.getElementById('edit-categoria').value = data.idCategoria;
                document.getElementById('edit-proveedor').value = data.idProveedor;
                document.getElementById('edit-costo').value = data.costoObtenido;
                document.getElementById('edit-precio').value = data.precioVendido;
                document.getElementById('edit-stock').value = data.stockActual;
            });
    }

    function abrirHistorial(id) {
        fetch(`/Producto/HistorialProducto/${id}`)
            .then(res => res.json())
            .then(historial => {
                const tbody = document.getElementById('historial-body');
                tbody.innerHTML = '';

                if (!historial || historial.length === 0) {
                    tbody.innerHTML = '<tr><td colspan="5" style="text-align:center; color:#9ca3af; padding:24px;">Sin movimientos registrados</td></tr>';
                    return;
                }

                historial.forEach(m => {
                    const badgeClass = m.tipoDeMovimiento?.toLowerCase().includes('entrada') ? 'badge-entrada' : 'badge-salida';
                    tbody.innerHTML += `
                        <tr>
                            <td><span class="${badgeClass}">${m.tipoDeMovimiento}</span></td>
                            <td>${m.cantidad}</td>
                            <td>${m.motivo || '—'}</td>
                            <td>${m.usuario?.nombreUsuario || '—'}</td>
                            <td>${new Date(m.fechaMovimiento).toLocaleDateString('es-PE')}</td>
                        </tr>`;
                });
            });
    }

    function guardarProducto(formId) {
        const form = document.getElementById(formId);
        const formData = new FormData(form);

        fetch('/Producto/GuardarProducto', {
            method: 'POST',
            body: formData
        })
        .then(res => res.json())
        .then(result => {
            if (result.resultado) location.reload();
            else alert(result.mensaje);
        });
    }

    function cambiarEstado(id) {
        fetch(`/Producto/CambiarEstadoProducto/${id}`, {
            method: 'POST',
            headers: {
                'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
            }
        })
        .then(res => res.json())
        .then(data => {
            if (data.resultado) location.reload();
            else alert(data.mensaje);
        });
    }
</script>
</body>
</html>
